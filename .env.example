# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
# Password/Token untuk login ke halaman admin (/admin)
ADMIN_TOKEN=your_admin_password_here

# Daftar keys untuk akses ekstensi (pisahkan dengan koma)
EXTENSION_KEYS=key1,key2,key3

# Secret token untuk memvalidasi webhook Telegram
TELEGRAM_WEBHOOK_SECRET=your_secret_webhook_string

# ==========================================
# DATABASE & CACHE
# ==========================================
# Service Account Firebase dalam satu baris JSON murni
# Contoh: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT=your_firebase_json_string_here

# Konfigurasi Upstash Redis (Layer 2 Cache)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ID Unik untuk memisahkan konfigurasi jika 1 Database dipakai multi-deploy/multi-Vercel
# Contoh: prod-client-a, prod-client-b (Kosongkan jika hanya ada 1 deployment)
CONFIG_ID=


# ==========================================
# AI PROVIDERS (LLM)
# Bisa multi-key (rotasi otomatis), pisahkan dengan koma
# ==========================================
# GROQ
GROQ_KEYS=gsk_xxx,gsk_yyy
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# GEMINI
GEMINI_KEYS=AIzaSy_xxx,AIzaSy_yyy
GEMINI_MODEL=gemini-2.5-flash

# MISTRAL
MISTRAL_KEYS=mistral_xxx,mistral_yyy
MISTRAL_MODEL=mistral-tiny

# ==========================================
# TELEGRAM BOT & WEBHOOK
# ==========================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Endpoint base URL Vercel kamu (opsional, untuk set webhook)
BASE_URL=https://your-vercel-domain.vercel.app

# ==========================================
# SERVER, LIMITS & TUNING
# ==========================================
# Batas request per API Key saat rotasi berjalan
MAX_CONCURRENT_PER_KEY=3

# Batas waktu tunggu API AI membalas (dalam ms)
PROVIDER_TIMEOUT=10000

# Batas maksimal ukuran karakter payload gambar/base64
MAX_BASE64_LENGTH=6000000

# Pengaturan CORS Allowed Origin
ALLOWED_ORIGIN=*

# [Hanya untuk Dev/Testing di komputer lokal]
# Setel ke 1 jika ingin menyimpan config di file lokal tanpa Firebase
# Diabaikan otomatis saat deploy ke Vercel/Lambda
LOCAL_FILE_STORE=1
